---
interface Props {
  id: string;
  name: string;
  price: number;
  description?: string;
  image?: string;
  url?: string;
  label?: string;
  class?: string;
}

const {
  id,
  name,
  price,
  description = '',
  image = '',
  url = '/',
  label = 'Add to Cart',
  class: className = '',
} = Astro.props;
---

<button
  class:list={[
    'snipcart-add-item inline-flex items-center gap-2 px-6 py-2.5 bg-gold-500 hover:bg-gold-400 text-elks-dark font-bold rounded-lg shadow-md hover:shadow-lg transition-all cursor-pointer',
    className,
  ]}
  data-item-id={id}
  data-item-name={name}
  data-item-price={price}
  data-item-description={description}
  data-item-image={image}
  data-item-url={url}
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4m1.6 8l-1.3 5.2A1 1 0 006.7 21H17M9 21a1 1 0 100-2 1 1 0 000 2zm8 0a1 1 0 100-2 1 1 0 000 2z"></path>
  </svg>
  {label} — ${price}
</button>

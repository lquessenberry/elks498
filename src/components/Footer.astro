---
const currentYear = new Date().getFullYear();
---

<footer class="bg-elks-dark text-purple-200">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Lodge Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/elks-logo.png" alt="Elks Logo" class="w-10 h-10 object-contain" loading="lazy" />
          <div>
            <div class="font-heading text-white font-bold">Jonesboro Elks</div>
            <div class="text-gold-400 text-xs">Lodge #498 · BPOE</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-4">
          Serving the Jonesboro, Arkansas community since 1899. 
          "The Faults of our Brothers we write upon the Sand, 
          their Virtues upon the Tablets of Love and Memory."
        </p>
        <div class="flex gap-3">
          <a href="https://www.facebook.com/jonesboro.elks" target="_blank" rel="noopener" class="w-8 h-8 bg-purple-800 rounded-full flex items-center justify-center hover:bg-[#1877F2] hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://x.com/JonesboroElks" target="_blank" rel="noopener" class="w-8 h-8 bg-purple-800 rounded-full flex items-center justify-center hover:bg-black hover:text-white transition-colors" aria-label="X (Twitter)">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.elks.org/lodges/home.cfm?LodgeNumber=498" target="_blank" rel="noopener" class="w-8 h-8 bg-purple-800 rounded-full flex items-center justify-center hover:bg-gold-500 hover:text-elks-dark transition-colors" aria-label="Elks.org">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-heading font-bold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="hover:text-gold-400 transition-colors">About Us</a></li>
          <li><a href="/events" class="hover:text-gold-400 transition-colors">Events & Calendar</a></li>
          <li><a href="/facilities" class="hover:text-gold-400 transition-colors">Facilities & Rentals</a></li>
          <li><a href="/dining" class="hover:text-gold-400 transition-colors">Dining & Specials</a></li>
          <li><a href="/membership" class="hover:text-gold-400 transition-colors">Become a Member</a></li>
          <li><a href="/charity" class="hover:text-gold-400 transition-colors">Charity & Community</a></li>
          <li><a href="/gallery" class="hover:text-gold-400 transition-colors">Photo Gallery</a></li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-white font-heading font-bold text-lg mb-4">Lodge Hours</h3>
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between"><span>Monday</span><span class="text-gold-400">4 PM – 10 PM</span></li>
          <li class="flex justify-between"><span>Tuesday</span><span class="text-gold-400">4 PM – 10 PM</span></li>
          <li class="flex justify-between"><span>Wednesday</span><span class="text-gold-400">4 PM – 10 PM</span></li>
          <li class="flex justify-between"><span>Thursday</span><span class="text-gold-400">4 PM – 10 PM</span></li>
          <li class="flex justify-between"><span>Friday</span><span class="text-gold-400">4 PM – 12 AM</span></li>
          <li class="flex justify-between"><span>Saturday</span><span class="text-gold-400">12 PM – 12 AM</span></li>
          <li class="flex justify-between"><span>Sunday</span><span class="text-gold-400">Closed</span></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-heading font-bold text-lg mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span>2113 W. Washington Ave.<br/>Jonesboro, AR 72401</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <a href="tel:+18709325498" class="hover:text-gold-400 transition-colors">(870) 932-5498</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gold-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:info@jonesboroelks.com" class="hover:text-gold-400 transition-colors">info@jonesboroelks.com</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-purple-800">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-purple-400">
      <p>&copy; {currentYear} Jonesboro Elks Lodge #498, BPOE. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/admin" class="hover:text-gold-400 transition-colors">Admin</a>
        <a href="https://www.elks.org" target="_blank" rel="noopener" class="hover:text-gold-400 transition-colors">Elks.org</a>
      </div>
    </div>
  </div>
</footer>

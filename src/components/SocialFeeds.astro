---
---
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-heading font-bold text-elks-red mb-3">Stay Connected</h2>
      <div class="w-16 h-1 bg-gold-500 rounded-full mx-auto mb-4"></div>
      <p class="text-gray-600 max-w-2xl mx-auto">Follow us on social media for the latest events, photos, and lodge updates.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Facebook Page Plugin -->
      <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
        <div class="bg-[#1877F2] px-6 py-4 flex items-center gap-3">
          <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          <span class="text-white font-bold">Facebook</span>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-4 mb-4">
            <img src="/images/lodge-fb-profile.jpg" alt="Jonesboro Elks Lodge 498" class="w-16 h-16 rounded-full object-cover border-2 border-red-200" loading="lazy" />
            <div>
              <h3 class="font-bold text-gray-900">Jonesboro Elks Lodge 498</h3>
              <p class="text-sm text-gray-500">@jonesboro.elks</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm mb-4">Follow our Facebook page for event announcements, photos from lodge activities, and community updates.</p>
          <a href="https://www.facebook.com/jonesboro.elks" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#1877F2] hover:bg-[#166FE5] text-white font-bold rounded-lg transition-colors text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Follow on Facebook
          </a>
        </div>
      </div>

      <!-- Twitter/X Timeline Embed -->
      <div class="bg-white rounded-xl shadow-md border border-gray-200 overflow-hidden">
        <div class="bg-black px-6 py-4 flex items-center gap-3">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span class="text-white font-bold">X (Twitter)</span>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-4 mb-4">
            <img src="/images/lodge-twitter-profile.jpg" alt="Jonesboro Elks on Twitter" class="w-16 h-16 rounded-full object-cover border-2 border-gray-200" loading="lazy" />
            <div>
              <h3 class="font-bold text-gray-900">Jonesboro Elks</h3>
              <p class="text-sm text-gray-500">@JonesboroElks</p>
            </div>
          </div>
          <p class="text-gray-600 text-sm mb-4">Follow us on X for real-time updates, event reminders, and lodge happenings.</p>
          <a href="https://x.com/JonesboroElks" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-black hover:bg-gray-800 text-white font-bold rounded-lg transition-colors text-sm">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Follow on X
          </a>
        </div>
      </div>
    </div>

    <!-- Elks National Links -->
    <div class="mt-8 bg-red-50 rounded-xl p-6 flex flex-wrap items-center justify-center gap-6 text-sm">
      <span class="text-gray-500 font-medium">National Elks:</span>
      <a href="https://www.elks.org" target="_blank" rel="noopener" class="text-elks-red font-bold hover:underline">elks.org</a>
      <a href="https://www.elks.org/enf/" target="_blank" rel="noopener" class="text-elks-red font-bold hover:underline">Elks National Foundation</a>
      <a href="https://www.elks.org/scholars/" target="_blank" rel="noopener" class="text-elks-red font-bold hover:underline">Scholarships</a>
      <a href="https://www.elks.org/vets/" target="_blank" rel="noopener" class="text-elks-red font-bold hover:underline">Veterans Services</a>
    </div>
  </div>
</section>

---
interface Props {
  title: string;
  subtitle?: string;
  backgroundClass?: string;
  showCtas?: boolean;
}

const { title, subtitle, backgroundClass = 'bg-elks-dark', showCtas = false } = Astro.props;
---

<section class:list={['relative overflow-hidden', backgroundClass]}>
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/images/lodge-officers.jpg" alt="" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-elks-dark/85 via-elks-dark/75 to-elks-dark/90"></div>
  </div>
  <!-- Decorative pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, rgba(212, 168, 67, 0.3) 0%, transparent 50%), radial-gradient(circle at 75% 75%, rgba(106, 13, 173, 0.3) 0%, transparent 50%);"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 py-20 md:py-32">
    <div class="text-center">
      <!-- Elks emblem placeholder -->
      <div class="mx-auto mb-6 w-24 h-24 md:w-32 md:h-32 rounded-full bg-gradient-to-br from-gold-400 to-gold-600 flex items-center justify-center shadow-2xl">
        <div class="w-20 h-20 md:w-28 md:h-28 rounded-full border-4 border-white/30 flex items-center justify-center">
          <img src="/images/lodge-fb-profile.jpg" alt="Elks Lodge #498" class="w-16 h-16 md:w-24 md:h-24 rounded-full object-cover" loading="eager" />
        </div>
      </div>

      <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white mb-4 drop-shadow-lg">
        {title}
      </h1>

      {subtitle && (
        <p class="text-lg md:text-xl text-purple-200 max-w-2xl mx-auto mb-8 leading-relaxed">
          {subtitle}
        </p>
      )}

      {showCtas && (
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/facilities" class="inline-flex items-center px-8 py-3 bg-gold-500 hover:bg-gold-400 text-elks-dark font-bold rounded-lg shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5">
            Rent the Hall
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
          <a href="/membership" class="inline-flex items-center px-8 py-3 bg-white/10 hover:bg-white/20 text-white font-bold rounded-lg border-2 border-white/30 backdrop-blur-sm transition-all">
            Join Today
          </a>
          <a href="/events" class="inline-flex items-center px-8 py-3 bg-purple-600 hover:bg-purple-500 text-white font-bold rounded-lg shadow-lg transition-all">
            View Events
          </a>
        </div>
      )}
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60V30C240 0 480 0 720 30C960 60 1200 60 1440 30V60H0Z" fill="white"/>
    </svg>
  </div>
</section>

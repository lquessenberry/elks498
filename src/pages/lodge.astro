---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const officers = (await getCollection('officers')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Our Lodge – Officers & Leadership" description="Meet the officers and leadership team of Jonesboro Elks Lodge #498.">
  <PageHero title="Our Lodge" subtitle="Meet the dedicated officers who lead Lodge #498." backgroundImage="/images/bpoe-emblem.jpg" />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeading title="Lodge Officers" subtitle="Our leadership team for the current lodge year." />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {officers.map((officer) => (
          <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 hover:shadow-xl transition-all group">
            <div class="bg-gradient-to-r from-elks-purple to-purple-700 px-6 py-4">
              <h3 class="text-gold-400 font-heading font-bold text-lg">{officer.data.title}</h3>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center">
                  <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-bold text-lg text-gray-900">{officer.data.name}</p>
                  {officer.data.email && (
                    <a href={`mailto:${officer.data.email}`} class="text-sm text-elks-purple hover:underline">{officer.data.email}</a>
                  )}
                </div>
              </div>
              {officer.data.bio && (
                <p class="text-gray-600 text-sm leading-relaxed">{officer.data.bio}</p>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Lodge Committees -->
      <div class="mt-16">
        <SectionHeading title="Lodge Committees" subtitle="Our committees keep the lodge running smoothly." />
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { name: 'House Committee', desc: 'Oversees lodge building maintenance, improvements, and operations.' },
            { name: 'Membership Committee', desc: 'Recruits new members and processes applications.' },
            { name: 'Activities Committee', desc: 'Plans and organizes lodge social events and gatherings.' },
            { name: 'Charity Committee', desc: 'Coordinates charitable giving and community outreach.' },
            { name: 'Youth Activities', desc: 'Manages scholarship programs, Hoop Shoot, and youth events.' },
            { name: 'Veterans Committee', desc: 'Supports veterans through programs and hospital visits.' },
          ].map(({ name, desc }) => (
            <div class="bg-purple-50 rounded-lg p-5 hover:bg-purple-100 transition-colors">
              <h3 class="font-heading font-bold text-elks-purple mb-2">{name}</h3>
              <p class="text-gray-600 text-sm">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

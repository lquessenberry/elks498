---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { getCollection } from 'astro:content';

const galleries = await getCollection('gallery');
---

<BaseLayout title="Photo Gallery" description="Browse photos from events, activities, and lodge life at Jonesboro Elks Lodge #498.">
  <PageHero title="Photo Gallery" subtitle="A picture is worth a thousand words. See what lodge life looks like!" backgroundImage="/images/lodge-building.jpg" />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      {galleries.map((gallery) => (
        <div class="mb-16">
          <h2 class="text-2xl font-heading font-bold text-elks-red mb-2">{gallery.data.title}</h2>
          {gallery.data.category && (
            <span class="inline-block bg-red-100 text-elks-red text-xs font-bold px-3 py-1 rounded-full mb-6">
              {gallery.data.category}
            </span>
          )}

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {gallery.data.images.map((image) => (
              <div class="group relative rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all aspect-video bg-red-100">
                {image.fbUrl ? (
                  <a href={image.fbUrl} target="_blank" rel="noopener noreferrer" class="block w-full h-full">
                    <img src={image.src} alt={image.alt} class="w-full h-full object-cover" loading="lazy" />
                    {image.caption && (
                      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-4 py-3 opacity-0 group-hover:opacity-100 transition-opacity">
                        <p class="text-white text-sm">{image.caption}</p>
                      </div>
                    )}
                  </a>
                ) : (
                  <>
                    <img src={image.src} alt={image.alt} class="w-full h-full object-cover" loading="lazy" />
                    {image.caption && (
                      <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent px-4 py-3 opacity-0 group-hover:opacity-100 transition-opacity">
                        <p class="text-white text-sm">{image.caption}</p>
                      </div>
                    )}
                  </>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}

      {galleries.length === 0 && (
        <div class="text-center py-12">
          <svg class="w-16 h-16 text-red-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <p class="text-gray-500">Photos coming soon!</p>
        </div>
      )}

      <!-- Photo submission CTA -->
      <div class="bg-red-50 rounded-2xl p-8 text-center mt-8">
        <h3 class="text-xl font-heading font-bold text-elks-red mb-3">Have Photos to Share?</h3>
        <p class="text-gray-600 mb-4">We'd love to add your lodge photos to our gallery. Email them to us!</p>
        <a href="mailto:photos@jonesboroelks.com" class="inline-flex items-center gap-2 px-6 py-3 bg-elks-red hover:bg-red-700 text-white font-bold rounded-lg transition-colors">
          Email Photos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

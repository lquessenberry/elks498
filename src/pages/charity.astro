---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
---

<BaseLayout title="Charity & Community Impact" description="Jonesboro Elks Lodge #498 gives back through scholarships, veterans support, youth programs, and community service.">
  <PageHero title="Charity & Community Impact" subtitle="Elks Care — Elks Share. Giving back is at the heart of everything we do." backgroundImage="/images/community.jpg" />

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Impact Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-16">
        {[
          { stat: '$10K+', label: 'Scholarships Awarded Annually' },
          { stat: '125+', label: 'Years of Service' },
          { stat: '500+', label: 'Active Members' },
          { stat: '1000s', label: 'Community Members Served' },
        ].map(({ stat, label }) => (
          <div class="text-center p-6 bg-gradient-to-br from-elks-purple to-purple-700 rounded-xl shadow-lg">
            <p class="text-3xl md:text-4xl font-bold text-gold-400 mb-1">{stat}</p>
            <p class="text-purple-200 text-sm">{label}</p>
          </div>
        ))}
      </div>

      <!-- Programs -->
      <SectionHeading title="Our Programs" subtitle="Lodge #498 supports a wide range of charitable programs." />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        {[
          {
            title: 'Youth Scholarships',
            desc: 'Each year we award thousands of dollars in scholarships to deserving local high school seniors. The Elks National Foundation provides additional scholarship opportunities at the state and national levels.',
            icon: 'M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z',
            img: '/images/scholarship.jpg',
          },
          {
            title: 'Veterans Services',
            desc: 'We support our veterans through hospital visits, care packages, holiday dinners, and assistance programs. The Elks have been the leading fraternal organization supporting veterans since 1946.',
            icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9',
            img: '/images/veterans.jpg',
          },
          {
            title: 'Hoop Shoot',
            desc: 'The Elks Hoop Shoot is a nationwide free-throw shooting contest for youth ages 8-13. Local winners advance through district, state, regional, and national competitions.',
            icon: 'M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
            img: '/images/elks-hoopshoot.png',
          },
          {
            title: 'Drug Awareness',
            desc: 'Our Drug Awareness Program educates young people about the dangers of substance abuse. We partner with local schools and community organizations to spread this vital message.',
            icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
            img: '/images/elks-disaster-relief-banner-3.jpg',
          },
          {
            title: 'Community Events',
            desc: 'From charity golf tournaments to holiday food drives, our lodge organizes events throughout the year that bring the community together and raise funds for important causes.',
            icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
            img: '/images/golf-charity.jpg',
          },
          {
            title: 'Elks National Foundation',
            desc: 'Our lodge contributes to the ENF, which is the charitable arm of the BPOE. The ENF invests over $500 million annually in communities nationwide through grants and programs.',
            icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
            img: '/images/elks-why-we-join.jpg',
          },
        ].map(({ title, desc, icon, img }) => (
          <div class="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden hover:shadow-xl transition-all">
            <div class="h-32 overflow-hidden">
              <img src={img} alt={title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gold-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon}></path>
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-elks-purple mb-2">{title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{desc}</p>
              </div>
            </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Elks Motto -->
      <div class="bg-gradient-to-r from-elks-dark via-purple-900 to-elks-dark rounded-2xl p-8 md:p-16 text-center">
        <div class="w-20 h-20 bg-gold-500 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-elks-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
        </div>
        <blockquote class="text-xl md:text-2xl text-purple-200 italic font-heading max-w-3xl mx-auto mb-4">
          "The faults of our Brothers we write upon the Sand, their Virtues upon the Tablets of Love and Memory."
        </blockquote>
        <p class="text-gold-400 font-bold">— The Elks Motto</p>
      </div>
    </div>
  </section>
</BaseLayout>
